<Window x:Class="AdvancedRdp.SessionToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Toolbar"
        Width="280"
        Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        Foreground="White"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight">
  <Border x:Name="ShellBorder"
          Background="#D9111820"
          BorderBrush="#55FFFFFF"
          BorderThickness="1"
          CornerRadius="10"
          Padding="8 6">
    <DockPanel>
      <Border x:Name="DragHandle"
              DockPanel.Dock="Left"
              Background="#22000000"
              CornerRadius="6"
              Padding="8 4"
              Margin="0 0 8 0">
        <TextBlock x:Name="TitleText"
                   VerticalAlignment="Center"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="White"
                   TextTrimming="CharacterEllipsis" />
      </Border>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="MinimizeButton"
                Content="最小化"
                Click="MinimizeButton_Click"
                Padding="10 4"
                MinWidth="54"
                Margin="0 0 6 0"
                FontSize="12" />
        <Button x:Name="ExitFullScreenButton"
                Content="退出全屏"
                Click="ExitFullScreenButton_Click"
                Padding="10 4"
                MinWidth="70"
                Margin="0 0 6 0"
                FontSize="12" />
        <Button x:Name="DisconnectButton"
                Content="断开"
                Click="DisconnectButton_Click"
                Padding="10 4"
                MinWidth="48"
                FontSize="12" />
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
