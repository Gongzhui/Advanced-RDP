<Window x:Class="AdvancedRdp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Advanced RDP"
        Height="820"
        Width="560"
        Background="{StaticResource PageBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource CardBrush}"
            Padding="18"
            Margin="18 18 18 10"
            CornerRadius="16"
            BorderBrush="{StaticResource AccentBorderBrush}"
            BorderThickness="1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0 0 0 12">
          <TextBlock Text="Advanced RDP" FontSize="22" FontWeight="Bold" Margin="0 0 0 4" />
          <TextBlock Text="轻量、安全、现代的远程桌面客户端"
                     Foreground="{StaticResource SubTextBrush}"
                     Margin="0 0 0 12" />
          <Button Content="新建主机" Click="NewHost_Click" Width="100" Style="{StaticResource PrimaryButton}" />

          <StackPanel Margin="0 12 0 0">
            <StackPanel Margin="0 0 0 8">
              <TextBlock Text="显示名称" Foreground="{StaticResource SubTextBrush}" />
              <TextBox x:Name="NameInput" />
            </StackPanel>

            <StackPanel Margin="0 0 0 8">
              <TextBlock Text="地址 (IP / 主机名)" Foreground="{StaticResource SubTextBrush}" />
              <TextBox x:Name="AddressInput" />
            </StackPanel>

            <StackPanel Margin="0 0 0 8">
              <TextBlock Text="用户名" Foreground="{StaticResource SubTextBrush}" />
              <TextBox x:Name="UserInput" />
            </StackPanel>

            <StackPanel Margin="0 0 0 8">
              <TextBlock Text="域（可选）" Foreground="{StaticResource SubTextBrush}" />
              <TextBox x:Name="DomainInput" />
            </StackPanel>

            <StackPanel Margin="0 0 0 12">
              <TextBlock Text="密码（保存到系统凭据）" Foreground="{StaticResource SubTextBrush}" />
              <PasswordBox x:Name="PasswordInput" />
            </StackPanel>

            <WrapPanel Margin="0 6 0 0">
              <CheckBox x:Name="SavePasswordCheck" Content="保存密码" IsChecked="True" />
              <CheckBox x:Name="RedirectClipboardCheck" Content="重定向剪贴板" IsChecked="True" />
              <CheckBox x:Name="FullScreenCheck" Content="全屏" IsChecked="True" />
              <CheckBox x:Name="DebugModeCheck" Content="调试模式" />
            </WrapPanel>

            <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
              <Button Content="保存" Click="SaveHost_Click" Width="90" />
              <Button Content="连接" Click="Connect_Click" Width="90" Margin="8 0 0 0" Style="{StaticResource PrimaryButton}" />
              <Button Content="删除" Click="DeleteHost_Click" Width="90" Margin="8 0 0 0" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="0 8 0 0">
          <TextBlock Text="已保存主机" FontWeight="Bold" Margin="0 0 0 6" />
          <ListBox x:Name="HostList"
                   ItemsSource="{Binding Hosts}"
                   DisplayMemberPath="Name"
                   SelectedItem="{Binding SelectedHost, Mode=TwoWay}"
                   SelectionChanged="HostList_SelectionChanged"
                   Height="220" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1"
            Background="{StaticResource CardBrush}"
            Padding="16"
            CornerRadius="16"
            BorderBrush="{StaticResource AccentBorderBrush}"
            BorderThickness="1"
            Margin="18 0 18 18">
      <StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="10" Height="10" Fill="#10B981" />
          <TextBlock x:Name="StatusText" Text="空闲，未连接" VerticalAlignment="Center" Margin="8 0 0 0" />
        </StackPanel>
        <TextBlock Text="每次点击连接都会打开独立会话窗口。开启调试模式后，会显示更详细的连接过程并写入日志文件。"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource SubTextBrush}"
                   Margin="0 6 0 0" />
        <TextBlock x:Name="DebugHintText"
                   Text=""
                   TextWrapping="Wrap"
                   Foreground="{StaticResource SubTextBrush}"
                   Margin="0 8 0 0" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
