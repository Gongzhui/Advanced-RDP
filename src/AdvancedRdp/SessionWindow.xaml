<Window x:Class="AdvancedRdp.SessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        mc:Ignorable="d"
        Title="RDP 会话"
        Height="860"
        Width="1320"
        Background="{StaticResource PageBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border x:Name="HeaderPanel"
            Grid.Row="0"
            Margin="14 14 14 10"
            Padding="14"
            CornerRadius="14"
            Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource AccentBorderBrush}"
            BorderThickness="1">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock x:Name="HostTitleText" FontSize="18" FontWeight="Bold" />
          <TextBlock x:Name="StatusText" Foreground="{StaticResource SubTextBrush}" Margin="0 4 0 0" />
          <TextBlock x:Name="LogPathText" Foreground="{StaticResource SubTextBrush}" Margin="0 4 0 0" Visibility="Collapsed" TextWrapping="Wrap" />
        </StackPanel>
        <Button x:Name="DisconnectButton"
                DockPanel.Dock="Right"
                Width="90"
                Margin="12 0 0 0"
                Content="断开"
                Click="Disconnect_Click" />
      </DockPanel>
    </Border>

    <Border x:Name="HostPanel"
            Grid.Row="1"
            Margin="14 0 14 10"
            CornerRadius="14"
            Background="#111827"
            BorderBrush="{StaticResource AccentBorderBrush}"
            BorderThickness="1">
      <Grid>
        <TextBlock x:Name="PlaceholderText"
                   Text="正在初始化远程桌面会话..."
                   Foreground="White"
                   Opacity="0.75"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
        <wfi:WindowsFormsHost x:Name="RdpHost" Background="Black" />
      </Grid>
    </Border>

    <Border x:Name="FooterPanel"
            Grid.Row="2"
            Margin="14 0 14 14"
            Padding="14"
            CornerRadius="14"
            Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource AccentBorderBrush}"
            BorderThickness="1">
      <StackPanel>
        <TextBlock Text="诊断与事件" FontWeight="Bold" />
        <TextBlock x:Name="DiagnosticText"
                   Margin="0 6 0 0"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource SubTextBrush}" />
        <TextBox x:Name="EventLogText"
                 Margin="0 8 0 0"
                 MinHeight="140"
                 MaxHeight="260"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
